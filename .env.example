# Copy to .env and fill in. The seed corpus + offline demo need NONE of these.
# LLM provider (Google Gemini). Free key: https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_VISION_MODEL=gemini-2.5-flash
EMBEDDINGS_MODEL=text-embedding-004
# local = deterministic/offline/zero-quota (default). gemini = semantic, uses quota.
EMBEDDINGS_PROVIDER=local

# Stores. Local/embedded is the default (no Docker needed).
GRAPH_BACKEND=networkx           # networkx | neo4j
VECTOR_BACKEND=local             # local | qdrant
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=plantcortex

# Free-tier rate-limit hygiene
LLM_MIN_INTERVAL_S=6.0
LLM_MAX_RETRY_WAIT_S=65.0

# Demo reliability: 1 = serve only cached/offline responses (no network at all)
DEMO_STRICT=0
LLM_CACHE_DIR=data/cache/llm
EMBED_CACHE_DIR=data/cache/embed
